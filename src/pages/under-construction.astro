---
// Standalone page — exempt from the under-construction redirect
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kenna Lewis — Coming Soon</title>
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html, body {
        height: 100%;
        font-family: Helvetica, Arial, sans-serif;
        background: #fff;
        color: #333;
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        padding: 2rem;
      }

      .card {
        max-width: 480px;
        width: 100%;
        text-align: left;
      }

      .label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #999;
        margin-bottom: 1.5rem;
      }

      h1 {
        font-size: 2rem;
        font-weight: 300;
        line-height: 1.2;
        margin-bottom: 1.25rem;
        color: #111;
      }

      .divider {
        width: 2rem;
        height: 1px;
        background: #ddd;
        margin-bottom: 2rem;
      }

      .contact {
        font-size: 0.85rem;
        color: #999;
        font-weight: 300;
        margin-top: 2rem;
      }

      .contact a {
        color: #333;
        text-decoration: none;
        border-bottom: 1px solid #ddd;
        transition: border-color 0.15s;
      }

      .contact a:hover {
        border-color: #999;
      }

      /* Password form */
      .password-row {
        display: flex;
        gap: 0.5rem;
        margin-top: 0.5rem;
      }

      input[type="password"] {
        flex: 1;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        font-family: inherit;
        font-weight: 300;
        border: 1px solid #ddd;
        outline: none;
        transition: border-color 0.15s;
        color: #333;
      }

      input[type="password"]:focus {
        border-color: #999;
      }

      input[type="password"].error {
        border-color: #e55;
      }

      button {
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        font-family: inherit;
        font-weight: 400;
        background: #333;
        color: #fff;
        border: none;
        cursor: pointer;
        transition: background 0.15s;
      }

      button:hover {
        background: #111;
      }

      .hint {
        font-size: 0.8rem;
        color: #e55;
        margin-top: 0.5rem;
        min-height: 1rem;
      }
    </style>
  </head>
  <body>
    <div class="card">
      <div class="label">kennalewis.com</div>
      <h1>Something new<br />is on its way.</h1>
      <div class="divider"></div>
      <div class="password-row">
        <input type="password" id="pw" placeholder="Password" autocomplete="off" />
        <button onclick="checkPassword()">Enter</button>
      </div>
      <div class="hint" id="hint"></div>
      <div class="contact">
        Reach me at <a href="mailto:mckennalewis2022@gmail.com">mckennalewis2022@gmail.com</a>
      </div>
    </div>

    <script>
      // If already unlocked, go straight to the site
      if (localStorage.getItem('site_unlocked') === 'yes') {
        window.location.replace('/');
      }

      function checkPassword() {
        const val = document.getElementById('pw').value;
        if (val === 'Junie') {
          localStorage.setItem('site_unlocked', 'yes');
          window.location.replace('/');
        } else {
          const input = document.getElementById('pw');
          const hint = document.getElementById('hint');
          input.classList.add('error');
          hint.textContent = 'Incorrect password.';
          input.value = '';
          input.focus();
        }
      }

      // Submit on Enter key
      document.getElementById('pw').addEventListener('keydown', function(e) {
        if (e.key === 'Enter') checkPassword();
      });
    </script>
  </body>
</html>
