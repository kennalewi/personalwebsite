---
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

// ─── Under Construction Mode ────────────────────────────────
// Set to true to redirect all site pages to /under-construction/
// Set to false to make the site live again
const UNDER_CONSTRUCTION = true;
// ────────────────────────────────────────────────────────────

interface Props {
  title: string;
}

const { title } = Astro.props;
const siteTitle = 'Kenna Lewis';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — {siteTitle}</title>
    {UNDER_CONSTRUCTION && (
      <script>
        // Redirect unless already unlocked via password
        if (
          window.location.pathname !== '/under-construction/' &&
          localStorage.getItem('site_unlocked') !== 'yes'
        ) {
          window.location.replace('/under-construction/');
        }
      </script>
    )}
  </head>
  <body>
    <div class="container">
      <div class="left-column">
        <Header />
        <nav>
          <Nav />
        </nav>
      </div>
      <div class="right-column">
        <main>
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
